{
  "name": "univer-plus",
  "type": "module",
  "version": "1.0.4",
  "packageManager": "pnpm@11.9.0",
  "description": "Create, edit, and view spreadsheets and documents in various formats like Excel and Word directly within your knowledge base.",
  "author": "DreamNum",
  "license": "Apache-2.0",
  "keywords": [
    "univer",
    "word",
    "excel",
    "spreadsheet",
    "document"
  ],
  "engines": {
    "node": ">=18",
    "pnpm": ">=11"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "release-it",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@univerjs/core": "0.25.1",
    "@univerjs/preset-docs-core": "0.25.1",
    "@univerjs/preset-sheets-conditional-formatting": "0.25.1",
    "@univerjs/preset-sheets-core": "0.25.1",
    "@univerjs/preset-sheets-data-validation": "0.25.1",
    "@univerjs/preset-sheets-filter": "0.25.1",
    "@univerjs/preset-sheets-find-replace": "0.25.1",
    "@univerjs/preset-sheets-hyper-link": "0.25.1",
    "@univerjs/preset-sheets-sort": "0.25.1",
    "@univerjs/themes": "0.25.1",
    "@xmldom/xmldom": "^0.9.10",
    "defu": "^6.1.4",
    "docx-preview": "^0.4.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.6.0",
    "@release-it/conventional-changelog": "^8.0.2",
    "@types/node": "^22.5.4",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.10.0",
    "lint-staged": "^15.2.10",
    "obsidian": "1.13.1",
    "release-it": "^17.6.0",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
